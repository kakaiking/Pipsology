# ==========================================
# DATABASE CONNECTION STRINGS (Prisma 7 & PG Adapter)
# ==========================================

# 1. Vercel Postgres Environment Variables (from your Vercel Dashboard)
# POSTGRES_PRISMA_URL is the pooled connection string (used in production queries)
# POSTGRES_URL_NON_POOLING is the direct connection string (used for schema migrations)
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# 2. Local Fallback Database Variable
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
